{{- if and (eq .chezmoi.os "darwin") (eq (.profile | default "client") "client") -}}
#!/usr/bin/env bash
# Install Homebrew (macOS arm64)
set -euo pipefail

if command -v brew >/dev/null 2>&1; then
  echo "✓ Homebrew already installed: $(brew --version | head -1)"
  exit 0
fi

if [ "$(uname -m)" != "arm64" ]; then
  echo "Error: unsupported architecture. This setup targets macOS arm64 (M1+)." >&2
  exit 1
fi

echo "==> Installing Homebrew..."
/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

if [ ! -x /opt/homebrew/bin/brew ]; then
  echo "Error: Homebrew installation completed but /opt/homebrew/bin/brew was not found." >&2
  exit 1
fi

echo "✓ Homebrew installed: $(/opt/homebrew/bin/brew --version | head -1)"
{{- end -}}
