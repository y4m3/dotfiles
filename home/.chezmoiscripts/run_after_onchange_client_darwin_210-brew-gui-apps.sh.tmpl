{{- if and (eq .chezmoi.os "darwin") (eq (.profile | default "client") "client") -}}
#!/usr/bin/env bash
# Install common GUI apps via Brewfile
# Brewfile.common hash: {{ include "dot_config/homebrew/Brewfile.common" | sha256sum }}
set -euo pipefail

BREW_BIN="/opt/homebrew/bin/brew"
BREWFILE="${HOME}/.config/homebrew/Brewfile.common"

if [ ! -x "$BREW_BIN" ]; then
  echo "Error: Homebrew not found at $BREW_BIN" >&2
  exit 1
fi

if [ ! -f "$BREWFILE" ]; then
  echo "Error: Brewfile not found: $BREWFILE" >&2
  exit 1
fi

echo "==> Checking common GUI applications..."
if "$BREW_BIN" bundle check --file="$BREWFILE" >/dev/null 2>&1; then
  echo "✓ All common GUI applications are already installed"
  exit 0
fi

echo "==> Installing common GUI applications via Brewfile..."
"$BREW_BIN" bundle install --file="$BREWFILE"
echo "✓ Common GUI applications installed"
{{- end -}}
