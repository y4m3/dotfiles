{{- $leader := "ctrl+w" -}}
{{- if hasKey .chezmoi.config.data "ghostty_leader" -}}
{{-   $leader = .ghostty_leader -}}
{{- end -}}
# ============================================================
# Ghostty Configuration
# ============================================================

# Theme
theme = TokyoNight Night

# Font
font-family = UDEV Gothic 35NFLG
font-size = 12
font-feature = -dlig

# Cursor
cursor-style = block
cursor-style-blink = false

# Window
window-padding-x = 10,0
window-padding-y = 10,0
window-save-state = always
background-opacity = 1.0
background-blur = false
macos-titlebar-style = hidden

# Mouse
mouse-hide-while-typing = true

# Clipboard
copy-on-select = clipboard

# Shell Integration
shell-integration = detect

# ============================================================
# Keybindings
# ============================================================
# Leader: {{ $leader }} (chord prefix, no timeout)
#
# Cheat Sheet:
#   Pane:  v=vsplit  s=hsplit  h/j/k/l=navigate  H/J/K/L=resize  x=close  f=zoom  e=equalize
#   Tab:   c=new  i/o=prev/next  I/O=move  1-9=goto  X=close
#   Misc:  N=new window  ?=inspector  r=reload config
#   Direct: ctrl+shift+c/v=copy/paste  super+c/v=copy/paste  ctrl+-/=/0=font size

# --- Pane: navigate ---
keybind = {{ $leader }}>h=goto_split:left
keybind = {{ $leader }}>j=goto_split:bottom
keybind = {{ $leader }}>k=goto_split:top
keybind = {{ $leader }}>l=goto_split:right

# --- Pane: resize (50px/step) ---
keybind = {{ $leader }}>shift+h=resize_split:left,50
keybind = {{ $leader }}>shift+j=resize_split:down,50
keybind = {{ $leader }}>shift+k=resize_split:up,50
keybind = {{ $leader }}>shift+l=resize_split:right,50

# --- Pane: split / close / zoom / equalize ---
keybind = {{ $leader }}>v=new_split:right
keybind = {{ $leader }}>s=new_split:down
keybind = {{ $leader }}>x=close_surface
keybind = {{ $leader }}>f=toggle_split_zoom
keybind = {{ $leader }}>e=equalize_splits

# --- Tab: navigate ---
keybind = {{ $leader }}>i=previous_tab
keybind = {{ $leader }}>o=next_tab

# --- Tab: move ---
keybind = {{ $leader }}>shift+i=move_tab:-1
keybind = {{ $leader }}>shift+o=move_tab:1

# --- Tab: goto (1-9) ---
keybind = {{ $leader }}>one=goto_tab:1
keybind = {{ $leader }}>two=goto_tab:2
keybind = {{ $leader }}>three=goto_tab:3
keybind = {{ $leader }}>four=goto_tab:4
keybind = {{ $leader }}>five=goto_tab:5
keybind = {{ $leader }}>six=goto_tab:6
keybind = {{ $leader }}>seven=goto_tab:7
keybind = {{ $leader }}>eight=goto_tab:8
keybind = {{ $leader }}>nine=goto_tab:9

# --- Tab: new / close ---
keybind = {{ $leader }}>c=new_tab
keybind = {{ $leader }}>shift+x=close_tab

# --- Utility ---
keybind = {{ $leader }}>shift+n=new_window
keybind = {{ $leader }}>shift+/=inspector:toggle
keybind = {{ $leader }}>r=reload_config

# --- Direct keys (no leader) ---
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = super+c=copy_to_clipboard
keybind = super+v=paste_from_clipboard
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+zero=reset_font_size

# ============================================================
# Local Overrides
# ============================================================
# Machine-specific settings (fonts, theme, keybindings, etc.)
# config.local is created once by chezmoi and never overwritten.
config-file = config.local
